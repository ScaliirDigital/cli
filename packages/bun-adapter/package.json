{
  "name": "@scale.digital/astro-bun",
  "version": "0.0.1",
  "description": "Astro 6 adapter for Bun with static file serving, ETag/304, and ISR",
  "keywords": [
    "astro",
    "astro-adapter",
    "bun",
    "ssr",
    "isr"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ScaliirDigital/cli",
    "directory": "packages/bun-adapter"
  },
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./server.js": "./dist/server.js",
    "./cache": "./dist/cache.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts ./src/server.ts ./src/cache.ts --outdir ./dist --target bun --external 'virtual:@scale.digital/astro-bun/config' --external astro"
  },
  "devDependencies": {
    "astro": "6.1.3",
    "bun-types": "1.3.11"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  }
}
